<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Cardre Governance Report</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:system-ui,-apple-system,sans-serif;color:#1e293b;background:#fff;line-height:1.5}
.container{max-width:1100px;margin:0 auto;padding:2em}
header{border-bottom:3px solid #0369a1;padding-bottom:1em;margin-bottom:2em}
header h1{font-size:1.6em;color:#0369a1}
header p{color:#64748b;margin-top:.3em;font-size:.9em}
h2{font-size:1.15em;color:#0369a1;margin:2em 0 .8em;padding-bottom:.3em;border-bottom:1px solid #e2e8f0}
h3{font-size:1em;color:#334155;margin:1.2em 0 .5em}
table{width:100%;border-collapse:collapse;margin:.8em 0 1.5em;font-size:.85em}
th{background:#f1f5f9;font-weight:600;text-align:left;padding:.5em .6em;border:1px solid #e2e8f0;white-space:nowrap}
td{padding:.4em .6em;border:1px solid #e2e8f0;vertical-align:top}
tr:nth-child(even){background:#f8fafc}
code{font-family:ui-monospace,SFMono-Regular,monospace;font-size:.85em;background:#f1f5f9;padding:.1em .3em;border-radius:3px}
.warning{background:#fef3c7;border:1px solid #f59e0b;padding:.6em 1em;margin:.5em 0;border-radius:6px;font-size:.85em}
.blocker{background:#fee2e2;border:1px solid #ef4444;padding:.6em 1em;margin:.5em 0;border-radius:6px;font-size:.85em}
.info{background:#e0f2fe;border:1px solid #0ea5e9;padding:.6em 1em;margin:.5em 0;border-radius:6px;font-size:.85em}
.section{page-break-inside:avoid}
.badge{display:inline-block;padding:.15em .5em;border-radius:4px;font-size:.8em;font-weight:600}
.badge-champion{background:#dbeafe;color:#1e40af}
.badge-target{background:#dcfce7;color:#166534}
.badge-warning{background:#fef3c7;color:#92400e}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:1em;margin:.5em 0 1em}
.stat-card{border:1px solid #e2e8f0;border-radius:6px;padding:.8em;background:#fafafa}
.stat-card .label{font-size:.75em;color:#64748b;text-transform:uppercase;letter-spacing:.03em}
.stat-card .value{font-size:1.2em;font-weight:600;color:#1e293b;margin-top:.2em}
.footer{margin-top:3em;padding-top:1em;border-top:1px solid #e2e8f0;font-size:.8em;color:#94a3b8}
</style>
</head>
<body>
<div class="container">

<header>
<h1>Cardre Governance Report</h1>
<p>
<strong>Project:</strong> {{ project_name }} &middot;
<strong>Run:</strong> <code>{{ run_id[:12] }}&hellip;</code> &middot;
<strong>Target Branch:</strong> <code>{{ target_branch_id }}</code> &middot;
<strong>Mode:</strong> {{ report_mode }} &middot;
<strong>Status:</strong> <span class="badge badge-{{ 'warning' if report_status and 'warning' in report_status else 'target' }}">{{ report_status }}</span>
</p>
<p>
<strong>Generated:</strong> {{ generated_at }}
</p>
</header>

{% set rs = run_status %}
{% if rs and rs.run_id %}
<section class="section">
<h2>Run Status</h2>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Run ID</td><td><code>{{ rs.run_id }}</code></td></tr>
<tr><td>Status</td><td><span class="badge {{ 'badge-warning' if rs.status != 'succeeded' else 'badge-target' }}">{{ rs.status or 'N/A' }}</span></td></tr>
<tr><td>Execution Mode</td><td>{{ rs.execution_mode }}</td></tr>
{% if rs.started_at %}<tr><td>Started</td><td>{{ rs.started_at }}</td></tr>{% endif %}
{% if rs.finished_at %}<tr><td>Finished</td><td>{{ rs.finished_at }}</td></tr>{% endif %}
{% if rs.target_step_id %}<tr><td>Target Step</td><td><code>{{ rs.target_step_id }}</code></td></tr>{% endif %}
{% if rs.short_circuit %}<tr><td>Short Circuit</td><td>Yes{% if rs.short_circuit_run_id %} (source run: <code>{{ rs.short_circuit_run_id[:12] }}&hellip;</code>){% endif %}</td></tr>{% endif %}
</tbody>
</table>
{% if rs.diagnostics %}
<h3>Diagnostics</h3>
<table>
<thead><tr><th>Code</th><th>Message</th><th>Severity</th><th>Category</th><th>Time</th></tr></thead>
<tbody>
{% for d in rs.diagnostics %}
<tr>
<td><code>{{ d.code }}</code></td>
<td>{{ d.message }}</td>
<td>{{ d.severity }}</td>
<td>{{ d.category }}</td>
<td>{{ d.created_at }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
</section>
{% endif %}

{% if limitations %}
<section class="section">
<h2>Limitations and Warnings</h2>
{% for w in limitations %}
<div class="{{ w.severity if w.severity in ('warning','blocker','info') else 'warning' }}">
<strong>{{ w.code }}:</strong> {{ w.message }}
</div>
{% endfor %}
</section>
{% endif %}

{% if summary %}
<section class="section">
<h2>Executive Summary</h2>
<div class="grid-2">
<div class="stat-card"><div class="label">Model Name</div><div class="value">{{ summary.model_name or 'N/A' }}</div></div>
<div class="stat-card"><div class="label">Target Column</div><div class="value">{{ summary.target_column or 'N/A' }}</div></div>
<div class="stat-card"><div class="label">Final Variables</div><div class="value">{{ summary.final_variable_count }}</div></div>
<div class="stat-card"><div class="label">Excluded Variables</div><div class="value">{{ summary.excluded_variable_count }}</div></div>
<div class="stat-card"><div class="label">Champion Branch</div><div class="value"><code>{{ summary.champion_branch_id or 'None' }}</code></div></div>
<div class="stat-card"><div class="label">Target Branch</div><div class="value"><code>{{ summary.target_branch_id }}</code></div></div>
</div>
</section>
{% endif %}

{% if modelling_metadata %}
<section class="section">
<h2>Project Scope</h2>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
{% if modelling_metadata.purpose %}<tr><td>Purpose</td><td>{{ modelling_metadata.purpose }}</td></tr>{% endif %}
{% if modelling_metadata.product %}<tr><td>Product</td><td>{{ modelling_metadata.product }}</td></tr>{% endif %}
{% if modelling_metadata.segment %}<tr><td>Segment</td><td>{{ modelling_metadata.segment }}</td></tr>{% endif %}
{% if modelling_metadata.observation_window %}<tr><td>Observation Window</td><td>{{ modelling_metadata.observation_window }}</td></tr>{% endif %}
{% if modelling_metadata.performance_window %}<tr><td>Performance Window</td><td>{{ modelling_metadata.performance_window }}</td></tr>{% endif %}
{% if modelling_metadata.reject_inference_position %}<tr><td>Reject Inference</td><td>{{ modelling_metadata.reject_inference_position }}</td></tr>{% endif %}
</tbody>
</table>
</section>
{% endif %}

{% if sample_definition and sample_definition.sample_method %}
<section class="section">
<h2>Sample Construction</h2>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Method</td><td>{{ sample_definition.sample_method }}</td></tr>
<tr><td>Domain</td><td>{{ sample_definition.sample_domain }}</td></tr>
{% if sample_definition.sample_description %}<tr><td>Description</td><td>{{ sample_definition.sample_description }}</td></tr>{% endif %}
</tbody>
</table>
</section>
{% endif %}

{% if exclusion_summary and exclusion_summary.rows_before > 0 %}
<section class="section">
<h2>Exclusions</h2>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Rows Before</td><td>{{ exclusion_summary.rows_before }}</td></tr>
<tr><td>Rows After</td><td>{{ exclusion_summary.rows_after }}</td></tr>
</tbody>
</table>
{% if exclusion_summary.rules %}
<h3>Exclusion Rules</h3>
<table>
<thead><tr><th>Rule</th><th>Reason</th><th>Rows Removed</th></tr></thead>
<tbody>
{% for r in exclusion_summary.rules %}
<tr><td>{{ r.rule_id }}</td><td>{{ r.reason }}</td><td>{{ r.rows_removed }}</td></tr>
{% endfor %}
</tbody>
</table>
{% endif %}
</section>
{% endif %}

{% if branches.branches %}
<section class="section">
<h2>Branches and Champion Selection</h2>
<table>
<thead><tr>
<th>Branch</th><th>Type</th><th>Status</th><th>Role</th>
</tr></thead>
<tbody>
{% for b in branches.branches %}
<tr>
<td><code>{{ b.branch_id }}</code></td>
<td>{{ b.name or b.branch_id }}</td>
<td>{{ b.status }}</td>
<td>
{% if b.is_champion %}<span class="badge badge-champion">Champion</span>{% endif %}
{% if b.is_target_branch %}<span class="badge badge-target">Target</span>{% endif %}
</td>
</tr>
{% endfor %}
</tbody>
</table>
{% if champion %}
<h3>Champion Assignment</h3>
<table>
<thead><tr><th>Field</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Status</td><td>{{ champion.champion_status }}</td></tr>
<tr><td>Branch</td><td><code>{{ champion.champion_branch_id or 'N/A' }}</code></td></tr>
{% if champion.rationale %}<tr><td>Rationale</td><td>{{ champion.rationale }}</td></tr>{% endif %}
{% if champion.comparison_artifact_id %}<tr><td>Comparison Artifact</td><td><code>{{ champion.comparison_artifact_id[:16] }}&hellip;</code></td></tr>{% endif %}
</tbody>
</table>
{% endif %}
</section>
{% endif %}

{% if variables %}
<section class="section">
<h2>Variable Information and WOE / IV Evidence</h2>

{% set initial_vars = variables | selectattr('role', 'equalto', 'initial') | list %}
{% set final_vars = variables | selectattr('role', 'ne', 'initial') | list %}

{% if initial_vars %}
<h3>Initial WOE / IV (Pre-Selection)</h3>
<table>
<thead><tr>
<th>Variable</th><th>IV</th>
</tr></thead>
<tbody>
{% for v in initial_vars %}
<tr>
<td><code>{{ v.variable_name }}</code></td>
<td>{{ v.iv | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

<h3>Final WOE / IV (Post-Manual Binning)</h3>
<table>
<thead><tr>
<th>Variable</th><th>IV</th><th>Bins</th><th>Monotonicity</th><th>Smoothing</th><th>Zero Cells</th>
</tr></thead>
<tbody>
{% for v in variables %}
<tr>
<td><code>{{ v.variable_name }}</code></td>
<td>{{ v.iv | fmt(".4f") }}</td>
<td>{{ v.final_bin_count }}</td>
<td>{{ v.monotonicity_status or 'N/A' }}</td>
<td>{{ 'Yes' if v.woe_smoothing and v.woe_smoothing.smoothing_applied else 'No' }}</td>
<td>{{ 'Yes' if v.woe_smoothing and v.woe_smoothing.zero_cell_encountered else 'No' }}</td>
</tr>
{% endfor %}
</tbody>
</table>

{% for v in variables %}
{% if v.woe_smoothing and v.woe_smoothing.smoothing_applied %}
<h3>Smoothing: {{ v.variable_name }}</h3>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Smoothing Enabled</td><td>{{ 'Yes' if v.woe_smoothing.enabled else 'No' }}</td></tr>
<tr><td>Method</td><td>{{ v.woe_smoothing.method }}</td></tr>
<tr><td>Alpha</td><td>{{ v.woe_smoothing.alpha }}</td></tr>
<tr><td>Zero-cell Policy</td><td>{{ v.woe_smoothing.zero_cell_policy }}</td></tr>
<tr><td>Affected Bins</td><td>{{ v.woe_smoothing.affected_bin_count }}</td></tr>
</tbody>
</table>
{% if v.affected_bins %}
<h4>Affected Bins Detail</h4>
<table>
<thead><tr>
<th>Bin</th><th>Reason</th><th>Raw Good</th><th>Raw Bad</th><th>Smoothed Good</th><th>Smoothed Bad</th><th>Final WOE</th>
</tr></thead>
<tbody>
{% for ab in v.affected_bins %}
<tr>
<td>{{ ab.bin_id }}</td>
<td>{{ ab.reason }}</td>
<td>{{ ab.raw_good_count }}</td>
<td>{{ ab.raw_bad_count }}</td>
<td>{{ ab.smoothed_good_count | fmt(".1f") }}</td>
<td>{{ ab.smoothed_bad_count | fmt(".1f") }}</td>
<td>{{ ab.final_woe | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
{% endif %}
{% endfor %}

{% for v in variables %}
{% if v.bins %}
<h3>Bins: {{ v.variable_name }}</h3>
<table>
<thead><tr>
<th>Bin</th><th>Label</th><th>Good</th><th>Bad</th><th>Bad Rate</th><th>WOE</th><th>IV Contribution</th>
</tr></thead>
<tbody>
{% for b in v.bins %}
<tr>
<td>{{ b.bin_id }}</td>
<td>{{ b.label }}</td>
<td>{{ b.good_count }}</td>
<td>{{ b.bad_count }}</td>
<td>{{ b.bad_rate | fmt(".4f") }}</td>
<td>{{ b.woe | fmt(".4f") }}</td>
<td>{{ b.iv_contribution | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
{% endfor %}
</section>
{% endif %}

{% if model and model.features %}
<section class="section">
<h2>Model Specification</h2>
<p><strong>Type:</strong> {{ model.model_type }} &middot;
<strong>Branch:</strong> <code>{{ model.branch_id }}</code> &middot;
<strong>Target:</strong> {{ model.target }}
</p>
<table>
<thead><tr>
<th>Variable</th><th>Coefficient</th><th>Std Error</th><th>P-Value</th>
</tr></thead>
<tbody>
{% for f in model.features %}
<tr>
<td><code>{{ f.variable_name }}</code></td>
<td>{{ f.coefficient | fmt(".6f") }}</td>
<td>{{ f.standard_error | fmt(".4f") }}</td>
<td>{{ f.p_value | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
</section>
{% endif %}

{% if model_diagnostics %}
<section class="section">
<h2>Model Diagnostics</h2>

{% if model_diagnostics.coefficient_sign_check %}
<h3>Coefficient Sign Check</h3>
<table>
<thead><tr>
<th>Variable</th><th>Coefficient</th><th>Sign</th><th>Expected</th><th>Status</th><th>Reason</th>
</tr></thead>
<tbody>
{% for e in model_diagnostics.coefficient_sign_check %}
<tr>
<td><code>{{ e.variable_name }}</code></td>
<td>{{ e.coefficient | fmt(".6f") }}</td>
<td>{{ e.coefficient_sign }}</td>
<td>{{ e.expected_sign }}</td>
<td>{{ e.status }}</td>
<td>{{ e.reason }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{% if model_diagnostics.separation_diagnostics %}
<h3>Separation Diagnostics</h3>
<table>
<thead><tr>
<th>Feature</th><th>Coefficient</th><th>Std Error</th><th>Status</th><th>Reason</th>
</tr></thead>
<tbody>
{% for e in model_diagnostics.separation_diagnostics %}
<tr>
<td><code>{{ e.feature_name }}</code></td>
<td>{{ e.coefficient | fmt(".4f") }}</td>
<td>{{ e.standard_error | fmt(".4f") if e.standard_error is not none else 'N/A' }}</td>
<td>{{ e.status }}</td>
<td>{{ e.reason }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{% if model_diagnostics.vif_diagnostics %}
<h3>Multicollinearity (VIF)</h3>
<table>
<thead><tr>
<th>Feature</th><th>VIF</th><th>Status</th><th>Reason</th>
</tr></thead>
<tbody>
{% for e in model_diagnostics.vif_diagnostics %}
<tr>
<td><code>{{ e.feature_name }}</code></td>
<td>{{ e.vif | fmt(".4f") if e.vif is not none else 'N/A' }}</td>
<td>{{ e.status }}</td>
<td>{{ e.reason }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}

{% if model_diagnostics.calibration_diagnostics %}
<h3>Calibration Diagnostics</h3>
{% for role_name, role_data in model_diagnostics.calibration_diagnostics.items() %}
<h4>Role: {{ role_name }}</h4>
<p>Status: {{ role_data.status }} &middot; HL Statistic: {{ role_data.hosmer_lemeshow_statistic | fmt(".4f") if role_data.hosmer_lemeshow_statistic is not none else 'N/A' }} &middot; Calibration Error: {{ role_data.calibration_error | fmt(".6f") }}</p>
{% if role_data.decile_bins %}
<table>
<thead><tr>
<th>Bin</th><th>Count</th><th>Observed Events</th><th>Expected Events</th><th>Observed Rate</th><th>Predicted Rate</th><th>Deviation</th>
</tr></thead>
<tbody>
{% for b in role_data.decile_bins %}
<tr>
<td>{{ b.bin }}</td>
<td>{{ b.count }}</td>
<td>{{ b.observed_events }}</td>
<td>{{ b.expected_events | fmt(".4f") }}</td>
<td>{{ b.observed_event_rate | fmt(".4f") }}</td>
<td>{{ b.predicted_event_rate | fmt(".4f") }}</td>
<td>{{ b.abs_deviation | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
{% endfor %}
{% endif %}

</section>
{% endif %}

{% if score_scaling and score_scaling.factor %}
<section class="section">
<h2>Score Scaling</h2>
<table>
<thead><tr><th>Parameter</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Base Score</td><td>{{ score_scaling.base_score }}</td></tr>
<tr><td>Base Odds</td><td>{{ score_scaling.base_odds }}</td></tr>
<tr><td>Points to Double Odds (PDO)</td><td>{{ score_scaling.points_to_double_odds }}</td></tr>
<tr><td>Factor</td><td>{{ score_scaling.factor | fmt(".4f") }}</td></tr>
<tr><td>Offset</td><td>{{ score_scaling.offset | fmt(".4f") }}</td></tr>
<tr><td>Direction</td><td>{{ score_scaling.score_direction }}</td></tr>
<tr><td>Rounding</td><td>{{ score_scaling.rounding }}</td></tr>
<tr><td>Score Range</td><td>{{ score_scaling.min_score }} &ndash; {{ score_scaling.max_score }}</td></tr>
</tbody>
</table>
</section>
{% endif %}

{% if validation and validation.metrics_by_role %}
<section class="section">
<h2>Validation Metrics</h2>
<table>
<thead><tr>
<th>Role</th><th>Rows</th><th>AUC</th><th>Gini</th><th>KS</th><th>Bad Rate</th>
</tr></thead>
<tbody>
{% for m in validation.metrics_by_role %}
<tr>
<td>{{ m.role }}</td>
<td>{{ m.row_count }}</td>
<td>{{ m.auc | fmt(".4f") }}</td>
<td>{{ m.gini | fmt(".4f") }}</td>
<td>{{ m.ks | fmt(".4f") }}</td>
<td>{{ m.bad_rate | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% if validation.stability and validation.stability.psi_by_role %}
<h3>Population Stability</h3>
<table>
<thead><tr><th>Comparison</th><th>Score PSI</th></tr></thead>
<tbody>
{% for p in validation.stability.psi_by_role %}
<tr><td>{{ p.comparison }}</td><td>{{ p.score_psi | fmt(".4f") }}</td></tr>
{% endfor %}
</tbody>
</table>
{% endif %}
</section>
{% endif %}

{% if cutoffs and cutoffs.cutoff_tables %}
<section class="section">
<h2>Cutoff Analysis</h2>
{% for ct in cutoffs.cutoff_tables %}
<h3>Role: {{ ct.role }}</h3>
<table>
<thead><tr>
<th>Score</th><th>Approval Rate</th><th>Bad Rate</th><th>Capture Rate</th>
</tr></thead>
<tbody>
{% for r in ct.rows %}
<tr>
<td>{{ r.score_cutoff }}</td>
<td>{{ r.approval_rate | fmt(".4f") }}</td>
<td>{{ r.bad_rate | fmt(".4f") }}</td>
<td>{{ r.capture_rate | fmt(".4f") }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endfor %}
{% if cutoffs.selected_cutoff and cutoffs.selected_cutoff.score %}
<p><strong>Selected cutoff:</strong> {{ cutoffs.selected_cutoff.score }} &middot;
<em>{{ cutoffs.selected_cutoff.selection_reason }}</em></p>
{% endif %}
</section>
{% endif %}

{% if variable_selection and variable_selection.selected_variables %}
<section class="section">
<h2>Variable Selection</h2>
<h3>Selected Variables</h3>
<p>{{ variable_selection.selected_variables | join(', ') }}</p>
{% if variable_selection.rejected_variables %}
<h3>Rejected Variables</h3>
<p>{{ variable_selection.rejected_variables | join(', ') }}</p>
{% endif %}
</section>
{% endif %}

{% if implementation_artifacts %}
<section class="section">
<h2>Implementation Artifacts</h2>
<table>
<thead><tr><th>Artifact</th><th>Type</th><th>ID</th></tr></thead>
<tbody>
{% if implementation_artifacts.scorecard_table %}
<tr><td>Scorecard Points Table</td><td>{{ implementation_artifacts.scorecard_table.schema_version }}</td><td><code>{{ implementation_artifacts.scorecard_table.artifact_id[:16] }}&hellip;</code></td></tr>
{% endif %}
{% if implementation_artifacts.scoring_export_python %}
<tr><td>Python Scoring Function</td><td>{{ implementation_artifacts.scoring_export_python.schema_version }}</td><td><code>{{ implementation_artifacts.scoring_export_python.artifact_id[:16] }}&hellip;</code></td></tr>
{% endif %}
{% if implementation_artifacts.scoring_export_sql %}
<tr><td>SQL Scoring Query</td><td>{{ implementation_artifacts.scoring_export_sql.schema_version }}</td><td><code>{{ implementation_artifacts.scoring_export_sql.artifact_id[:16] }}&hellip;</code></td></tr>
{% endif %}
</tbody>
</table>
</section>
{% endif %}

{% if manual_interventions %}
<section class="section">
<h2>Manual Interventions</h2>
<table>
<thead><tr>
<th>Type</th><th>Variable</th><th>Reason</th><th>Branch</th>
</tr></thead>
<tbody>
{% for mi in manual_interventions %}
<tr>
<td>{{ mi.type }}</td>
<td>{{ mi.variable_name }}</td>
<td>{{ mi.reason or 'No reason provided' }}</td>
<td><code>{{ mi.branch_id }}</code></td>
</tr>
{% endfor %}
</tbody>
</table>
</section>
{% endif %}

{% if redundancy_review.cluster_count > 0 or redundancy_review.singleton_count > 0 %}
<section class="section">
<h2>Redundancy and Variable Clustering Review</h2>

<table class="meta-table">
  <tr><th>Method</th><td>{{ redundancy_review.method }}</td></tr>
  <tr><th>Input Representation</th><td>{{ redundancy_review.input_representation }}</td></tr>
  <tr><th>Similarity Metric</th><td>{{ redundancy_review.similarity_metric }}</td></tr>
  {% if redundancy_review.threshold is not none %}
  <tr><th>Threshold</th><td>{{ redundancy_review.threshold }}</td></tr>
  {% endif %}
  <tr><th>Absolute Correlation</th><td>{{ redundancy_review.absolute_correlation }}</td></tr>
  <tr><th>Missing Handling</th><td>{{ redundancy_review.missing_handling }}</td></tr>
  <tr><th>Candidate Limit</th><td>{{ redundancy_review.candidate_limit }}</td></tr>
  <tr><th>Representative Rule</th><td>{{ redundancy_review.representative_rule }}</td></tr>
  <tr><th>Clusters</th><td>{{ redundancy_review.cluster_count }}</td></tr>
  <tr><th>Singleton Variables</th><td>{{ redundancy_review.singleton_count }}</td></tr>
</table>

{% if redundancy_review.clusters %}
<h3>Clusters</h3>
<table>
  <thead>
    <tr>
      <th>Cluster</th>
      <th>Variables</th>
      <th>Suggested Representative</th>
      <th>Reason</th>
      <th>Max Corr</th>
    </tr>
  </thead>
  <tbody>
    {% for cl in redundancy_review.clusters %}
    <tr>
      <td><code>{{ cl.cluster_id }}</code></td>
      <td>{{ cl.variables | map(attribute='variable') | join(', ') }}</td>
      <td>{{ cl.representative_suggestion or '—' }}</td>
      <td>{{ cl.representative_reason }}</td>
      <td>{{ '%.4f' | format(cl.max_pairwise_abs_corr) if cl.max_pairwise_abs_corr is not none else '—' }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% if redundancy_review.singleton_variables %}
<h3>Singleton Variables</h3>
<p>{{ redundancy_review.singleton_variables | join(', ') }}</p>
{% endif %}

{% if redundancy_review.warnings %}
<h3>Warnings</h3>
<ul>
  {% for w in redundancy_review.warnings %}
  <li>{{ w.message }}</li>
  {% endfor %}
</ul>
{% endif %}
</section>
{% endif %}

{% if reproducibility %}
<section class="section">
<h2>Reproducibility Manifest</h2>
<table>
<thead><tr><th>Property</th><th>Value</th></tr></thead>
<tbody>
<tr><td>Run ID</td><td><code>{{ reproducibility.run_id }}</code></td></tr>
{% if reproducibility.manifest_hash %}<tr><td>Manifest Hash</td><td><code>{{ reproducibility.manifest_hash }}</code></td></tr>{% endif %}
<tr><td>Cardre Version</td><td>{{ reproducibility.report_generation.cardre_version if reproducibility.report_generation else '0.1.0' }}</td></tr>
</tbody>
</table>
{% if reproducibility.execution_fingerprints %}
<h3>Execution Fingerprints</h3>
<table>
<thead><tr><th>Step</th><th>Python</th><th>Platform</th></tr></thead>
<tbody>
{% for fp in reproducibility.execution_fingerprints %}
<tr>
<td><code>{{ fp.step_id[:30] }}&hellip;</code></td>
<td>{{ fp.python_version }}</td>
<td>{{ fp.platform }}</td>
</tr>
{% endfor %}
</tbody>
</table>
{% endif %}
</section>
{% endif %}

{% if artifacts %}
<section class="section">
<h2>Artifact Index</h2>
<table>
<thead><tr>
<th>ID</th><th>Type</th><th>Role</th><th>Logical Hash</th>
</tr></thead>
<tbody>
{% for a in artifacts %}
<tr>
<td><code>{{ a.artifact_id[:12] }}&hellip;</code></td>
<td>{{ a.artifact_type }}</td>
<td>{{ a.role }}</td>
<td><code>{{ a.logical_hash[:12] }}&hellip;</code></td>
</tr>
{% endfor %}
</tbody>
</table>
</section>
{% endif %}

<div class="footer">
<p>Generated by Cardre &middot; {{ generated_at }}</p>
<p>PDF export is out of scope for this report phase. The canonical format is <code>report_bundle.json</code>.</p>
</div>

</div>
</body>
</html>
